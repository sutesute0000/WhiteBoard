# コピーして `.env` を作成し、各値を埋めてください
# cp .env.example .env

# Azure OpenAI (必須)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Speech (任意: マイク入力)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=japaneast

# Cosmos DB (任意: 永続化)
# STORE=cosmos
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=
# COSMOS_DATABASE=whiteboard

PORT=8787

# LLM 呼び出し最小インターバル (ms)
LLM_MIN_INTERVAL_MS=10000
